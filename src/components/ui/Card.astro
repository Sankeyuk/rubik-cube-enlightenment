---
interface Props {
  as?: "article" | "section" | "div" | "li";
}

const { as: Tag = "article" } = Astro.props;
---

<Tag class="card">
  <slot />
</Tag>

<style>
  .card {
    display: grid;
    gap: var(--space-md);
    min-width: 0;
    padding: var(--space-lg);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    background: var(--color-surface);
    box-shadow: var(--shadow-none);
  }
</style>
