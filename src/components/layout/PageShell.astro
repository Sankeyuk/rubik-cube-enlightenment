---
interface Props {
  tone?: "default" | "quiet";
}

const { tone = "default" } = Astro.props;
---

<main class:list={["page-shell", `tone-${tone}`]}>
  <slot />
</main>

<style>
  .page-shell {
    display: grid;
    gap: var(--space-2xl);
    width: min(100% - 32px, var(--page-max-width));
    margin: 0 auto;
    padding: var(--space-xl) 0 0;
  }

  .tone-quiet {
    gap: var(--space-xl);
  }

  @media (min-width: 720px) {
    .page-shell {
      padding-top: var(--space-2xl);
    }
  }
</style>
