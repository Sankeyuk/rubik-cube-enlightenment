---
import { navigation } from "../../data/navigation";
import { site } from "../../data/site";
import { routePath, sitePath } from "../../utils/paths";

const currentPath = routePath(Astro.url.pathname).replace(/\/$/, "") || "/";
---

<header class="site-header">
  <a class="brand" href={sitePath("/")} aria-label={`${site.title} 首页`}>
    <span class="brand-mark" aria-hidden="true">魔</span>
    <span>
      <strong>{site.title}</strong>
      {site.chineseTitle && <small>{site.chineseTitle}</small>}
    </span>
  </a>
  <nav class="nav" aria-label="主导航">
    {
      navigation.map((item) => (
        <a
          class:list={["nav-link", currentPath === item.href && "is-active"]}
          href={sitePath(item.href)}
          data-analytics-event={item.href === "/support" ? "support_click" : undefined}
          data-analytics-props={item.href === "/support" ? JSON.stringify({ source_path: currentPath, source_label: "header_nav" }) : undefined}
        >
          {item.label}
        </a>
      ))
    }
  </nav>
</header>

<style>
  .site-header {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
    width: min(100% - 32px, var(--page-max-width));
    margin: 0 auto;
    padding: var(--space-lg) 0 var(--space-md);
  }

  .brand {
    display: inline-flex;
    align-items: center;
    gap: var(--space-sm);
    width: fit-content;
    color: var(--color-on-neutral);
    text-decoration: none;
  }

  .brand-mark {
    display: inline-grid;
    width: 36px;
    height: 36px;
    place-items: center;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    background: var(--color-surface);
    color: var(--color-primary);
    font-weight: 700;
  }

  .brand strong,
  .brand small {
    display: block;
  }

  .brand strong {
    font-size: 0.96rem;
    line-height: 1.2;
  }

  .brand small {
    color: var(--color-muted-text);
    font-size: var(--font-size-caption);
    line-height: var(--line-height-caption);
  }

  .nav {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-xs);
    width: 100%;
    padding: var(--space-xs);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    background: rgba(255, 255, 255, 0.72);
  }

  .nav-link {
    flex: 1 1 72px;
    min-width: 62px;
    padding: 8px 10px;
    border-radius: var(--radius-sm);
    color: var(--color-muted-text);
    font-size: var(--font-size-caption);
    line-height: var(--line-height-caption);
    text-align: center;
    text-decoration: none;
  }

  .nav-link.is-active {
    background: var(--color-surface);
    color: var(--color-on-neutral);
    box-shadow: var(--shadow-sm);
  }

  @media (min-width: 720px) {
    .site-header {
      flex-direction: row;
      align-items: center;
      justify-content: space-between;
      padding-top: var(--space-xl);
    }

    .nav {
      width: auto;
      min-width: 260px;
      flex-wrap: nowrap;
    }
  }
</style>
