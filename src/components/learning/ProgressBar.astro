---
interface OverallProgress {
  completedUnits: number;
  totalUnits: number;
  label: string;
  description: string;
}

interface Props {
  progress: OverallProgress;
}

const { progress } = Astro.props;
const current = Math.round((progress.completedUnits / progress.totalUnits) * 100);
---

<section class="progress-panel" aria-labelledby="progress-title">
  <div class="progress-heading">
    <span class="eyebrow">整体复原进度</span>
    <strong id="progress-title">{current}%</strong>
  </div>
  <p class="progress-note">
    网站不记录你的状态。这个进度条按 6 个面 × 每面 8 格 = {progress.totalUnits} 格估算，帮你对照整颗魔方已经完成到哪里。
  </p>
  <div class="track" aria-hidden="true">
    <span style={`width: ${current}%`}></span>
  </div>
  <div class="progress-summary">
    <span>{progress.completedUnits}/{progress.totalUnits} 格</span>
    <div>
      <strong>{progress.label}</strong>
      <p>{progress.description}</p>
    </div>
  </div>
</section>

<style>
  .progress-panel {
    display: grid;
    gap: var(--space-md);
    padding: var(--space-lg);
    border: 1px solid rgba(74, 144, 226, 0.24);
    border-radius: var(--radius-lg);
    background: rgba(74, 144, 226, 0.08);
  }

  .progress-heading {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-md);
  }

  .eyebrow,
  .progress-note,
  .progress-list span {
    color: var(--color-muted-text);
    font-size: var(--font-size-caption);
    line-height: var(--line-height-caption);
  }

  .progress-heading strong {
    color: var(--color-primary);
    font-size: var(--font-size-h3);
  }

  .track {
    overflow: hidden;
    height: 10px;
    border-radius: var(--radius-full);
    background: var(--color-surface);
  }

  .track span {
    display: block;
    height: 100%;
    border-radius: inherit;
    background: var(--color-primary);
  }

  .progress-summary {
    display: grid;
    grid-template-columns: 48px minmax(0, 1fr);
    gap: var(--space-sm);
    align-items: start;
  }

  .progress-summary strong {
    display: block;
    line-height: 1.4;
  }

  .progress-summary p {
    margin: 0;
    color: var(--color-muted-text);
  }
</style>
