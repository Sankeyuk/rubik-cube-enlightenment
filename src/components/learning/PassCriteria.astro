---
interface Props {
  items: string[];
}

const { items } = Astro.props;
---

<section class="pass-criteria" aria-labelledby="pass-title">
  <h2 id="pass-title">做到什么算完成</h2>
  <ul>
    {items.map((item) => <li>{item}</li>)}
  </ul>
</section>

<style>
  .pass-criteria,
  ul {
    display: grid;
    gap: var(--space-md);
  }

  ul {
    margin: 0;
    padding: 0;
    list-style: none;
  }

  li {
    padding-left: 28px;
    color: var(--color-muted-text);
    background: radial-gradient(circle at 8px 0.75em, var(--color-accent-green) 0 4px, transparent 5px) no-repeat;
  }
</style>
