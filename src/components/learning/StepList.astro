---
interface Props {
  title: string;
  items: string[];
}

const { title, items } = Astro.props;
---

<section class="step-section" aria-labelledby={`${title}-title`}>
  <h2 id={`${title}-title`}>{title}</h2>
  <ol class="step-list">
    {items.map((item, index) => <li><span>Step {index + 1}</span><p>{item}</p></li>)}
  </ol>
</section>

<style>
  .step-section,
  .step-list {
    display: grid;
    gap: var(--space-md);
  }

  .step-list {
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .step-list li {
    display: grid;
    grid-template-columns: 72px minmax(0, 1fr);
    gap: var(--space-sm);
    align-items: start;
  }

  .step-list span {
    display: grid;
    min-height: 34px;
    place-items: center;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    background: var(--color-surface-muted);
    color: var(--color-primary);
    font-size: var(--font-size-caption);
    font-weight: 700;
  }
</style>
